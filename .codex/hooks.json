{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'CAVEMAN MODE ACTIVE. Rules: Drop articles/filler/pleasantries/hedging. Fragments OK. Short synonyms. Pattern: [thing] [action] [reason]. [next step]. Not: Sure! I would be happy to help you with that. Yes: Bug in auth middleware. Fix: Code/commits/security: write normal. User says stop caveman or normal mode to deactivate.'",
            "timeout": 5,
            "statusMessage": "Loading caveman mode"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/user_prompt_rules.sh"
          }
        ]
      }
    ],
  "PreToolUse": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "python3 .codex/hooks/qa_pretool.py"
        }
      ]
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
            "command": "bash .codex/hooks/graphify_presearch.sh"
          }
        ]
      }
    ],
  "PostToolUse": [
    {
      "matcher": "Edit|Write|MultiEdit|ApplyPatch",
      "hooks": [
        {
          "type": "command",
          "command": ".codex/hooks/graphify_posttool.sh"
        },
        {
          "type": "command",
          "command": "python3 .codex/hooks/qa_posttool.py"
        }
      ]
    }
  ]
}
}
